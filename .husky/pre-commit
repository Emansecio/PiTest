#!/bin/sh

# Get list of staged files before running check
STAGED_FILES=$(git diff --cached --name-only)

# Static checks only (tsgo + biome + smokes, ~5s). Unit/full vitest run on
# pre-push via `npm run check` and locally via `npm run check:fast`.
echo "Running static checks (lint, types, smoke)..."
npm run check:static
if [ $? -ne 0 ]; then
  echo "❌ Checks failed. Please fix the errors before committing."
  exit 1
fi

# Restage files that were previously staged and may have been modified by formatting.
# Skip gitignored paths (e.g. .pit/ runtime caches a test run may regenerate) so the
# re-stage never fails on a file the project intentionally does not track.
for file in $STAGED_FILES; do
  if [ -f "$file" ] && ! git check-ignore -q "$file"; then
    git add "$file"
  fi
done

echo "✅ All pre-commit checks passed!"
