{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"incremental": true,
		"tsBuildInfoFile": "./.tsbuildinfo",
		"declarationMap": false,
		"sourceMap": false,
		"inlineSources": false
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts"],
	"exclude": ["node_modules", "dist"]
}
