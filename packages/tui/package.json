{
	"name": "@pit/tui",
	"version": "0.75.4",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./core": {
			"types": "./dist/core.d.ts",
			"import": "./dist/core.js"
		}
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "node --test --import tsx --import ./test/_render-assert-setup.ts test/*.test.ts",
		"bench:render": "node --import tsx test/render-transcript.bench.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"author": "PiTuned",
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"get-east-asian-width": "^1.3.0",
		"marked": "^15.0.12"
	},
	"optionalDependencies": {
		"koffi": "^2.9.0"
	},
	"devDependencies": {
		"@xterm/headless": "^5.5.0",
		"@xterm/xterm": "^5.5.0",
		"chalk": "^5.5.0"
	}
}
