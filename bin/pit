#!/usr/bin/env bash
# PiTuned launcher (bash / Git Bash / WSL).
# Runs the local PiTest source via tsx, isolated from the global `pit` install
# by pointing the agent dir at ~/.pit/agent/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Isolate PiTuned state (settings, sessions, installed packages) from stock pit.
# Honor any explicit override the user set before invoking pit.
: "${PIT_CODING_AGENT_DIR:=$HOME/.pit/agent}"
export PIT_CODING_AGENT_DIR

# Isolate temp dir to avoid clashes with ACL-locked CodexSandbox temp folders.
: "${PIT_TMP_DIR:=$HOME/.pit/tmp}"
mkdir -p "$PIT_TMP_DIR"
export TMP="$PIT_TMP_DIR" TEMP="$PIT_TMP_DIR" PIT_TMP_DIR

TSX_BIN="$REPO_ROOT/node_modules/.bin/tsx"
if [[ ! -x "$TSX_BIN" ]]; then
  echo "pit: tsx not found at $TSX_BIN. Run \`npm install\` in $REPO_ROOT first." >&2
  exit 1
fi

CLI="$REPO_ROOT/packages/coding-agent/src/cli.ts"
exec "$TSX_BIN" "$CLI" "$@"
